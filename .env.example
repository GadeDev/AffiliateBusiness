# AffiliateBusiness environment template
#
# Secrets must not be committed. Copy this file to .env.local for local checks.
# Production values belong in GitHub Secrets / GitHub Variables / Cloudflare Secrets.

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# Production Neon PostgreSQL. Leave unset for local SQLite.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local SQLite override. Usually not needed; the app auto-detects repo-root data/clicks.db.
# DATABASE_PATH=/absolute/path/to/AffiliateBusiness/data/clicks.db

# ------------------------------------------------------------
# Public URLs
# ------------------------------------------------------------

# GitHub Variable recommended:
WEB_BASE_URL=https://affiliate-web.yanagiho.workers.dev
NEXT_PUBLIC_BASE_URL=https://affiliate-web.yanagiho.workers.dev

# ------------------------------------------------------------
# Admin auth
# ------------------------------------------------------------

# Generate with: openssl rand -base64 32
# AUTH_SECRET=replace-with-random-secret

# Single-user fallback. Production may use ADMIN_USERS JSON instead.
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=replace-with-strong-password

# Example:
# ADMIN_USERS=[{"username":"admin","password":"..."},{"username":"hakamagi","password":"..."}]

# ------------------------------------------------------------
# AI / notifications
# ------------------------------------------------------------

# ANTHROPIC_API_KEY=sk-ant-...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ------------------------------------------------------------
# X API v2
# ------------------------------------------------------------
#
# Automated posting uses per-account secrets:
# TW_<SLUG>_API_KEY
# TW_<SLUG>_API_SECRET
# TW_<SLUG>_ACCESS_TOKEN
# TW_<SLUG>_ACCESS_SECRET
#
# Current planned slugs:
# CAREER_SCOPE_JP
# ASSET_BRIEF_JP
# KAKEI_RESET_NOTE
# LOVE_SIGNAL_EDIT
# BASEBALL_POINT_JP

TW_CAREER_SCOPE_JP_API_KEY=
TW_CAREER_SCOPE_JP_API_SECRET=
TW_CAREER_SCOPE_JP_ACCESS_TOKEN=
TW_CAREER_SCOPE_JP_ACCESS_SECRET=

TW_ASSET_BRIEF_JP_API_KEY=
TW_ASSET_BRIEF_JP_API_SECRET=
TW_ASSET_BRIEF_JP_ACCESS_TOKEN=
TW_ASSET_BRIEF_JP_ACCESS_SECRET=

TW_KAKEI_RESET_NOTE_API_KEY=
TW_KAKEI_RESET_NOTE_API_SECRET=
TW_KAKEI_RESET_NOTE_ACCESS_TOKEN=
TW_KAKEI_RESET_NOTE_ACCESS_SECRET=

TW_LOVE_SIGNAL_EDIT_API_KEY=
TW_LOVE_SIGNAL_EDIT_API_SECRET=
TW_LOVE_SIGNAL_EDIT_ACCESS_TOKEN=
TW_LOVE_SIGNAL_EDIT_ACCESS_SECRET=

TW_BASEBALL_POINT_JP_API_KEY=
TW_BASEBALL_POINT_JP_API_SECRET=
TW_BASEBALL_POINT_JP_ACCESS_TOKEN=
TW_BASEBALL_POINT_JP_ACCESS_SECRET=

# Legacy single-account fallback used by old manual SNS flow.
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
